#!/usr/bin/env bash

PORT="$1"

if [[ -n "$PORT" ]]; then
  ARGS=(-iTCP:"$PORT" -iUDP:"$PORT")
else
  ARGS=(-iTCP -iUDP)
fi

# Privileged ports
if [[ -n "$PORT" && "$PORT" -lt 1024 ]]; then
  exec sudo lsof -nP "${ARGS[@]}"
fi

# Try without sudo, fallback to sudo
lsof -nP "${ARGS[@]}" 2>/dev/null || sudo lsof -nP "${ARGS[@]}"

